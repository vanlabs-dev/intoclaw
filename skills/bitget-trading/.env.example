# Bitget API credentials
# Generate at: https://www.bitget.com/account/newapi
# Requires: API key, secret, and passphrase (set during key creation)
# Permissions needed: Read, Trade (enable Withdraw only if you need it)
# IP whitelisting: strongly recommended for production use

BITGET_API_KEY=your_api_key_here
BITGET_API_SECRET=your_api_secret_here
BITGET_API_PASSPHRASE=your_passphrase_here

# AgentMail (OPTIONAL) — agent-managed email for registration
# Only needed if you want the agent to create a dedicated email address
# instead of using the user's personal email. Most users won't need this.
# Note: some exchanges may block @agentmail.to addresses.
# Get a key at: https://console.agentmail.to (free tier: 3 inboxes, 3k emails/mo)

# AGENTMAIL_API_KEY=your_agentmail_key_here
